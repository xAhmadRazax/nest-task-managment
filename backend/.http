@baseUrl = http://localhost:3000/api/v1
@content-type = application/json
### 
# @name registerUser
POST {{baseUrl}}/auth/register
Content-Type:{{content-type}}

{
    "name":"fake",
    "email":"fakeq113@fake.com",
    "password":"Fake123*"
}

### 
# @name loginUser
POST {{baseUrl}}/auth/login
Content-Type:{{content-type}}

{
    "email":"fake@fake.com",
    "password":"Fake123*"
}

### setting access token
@accessToken = {{loginUser.response.body.accessToken}}


### 
# @name changePassword
POST {{baseUrl}}/auth/change-password
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}

{
    "currentPassword":"Fake123*",
    "newPassword":"Fakefake12*"
}

### 
# @name forgotPassword
POST {{baseUrl}}/auth/forgot-password
Content-Type:{{content-type}}

{
    "email":"fake@fake.com"
}

### setting access token
@passwordResetUrl = {{forgotPassword.response.body.passwordResetUrl}}


### 
# @name resetPassword
POST {{passwordResetUrl}}
Content-Type:{{content-type}}

{
    "password":"Fake123*"
}



### logout user
# @name logout
POST  {{baseUrl}}/auth/logout
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}



### getting user
# @name getMe

GET {{baseUrl}}/auth/me
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}


