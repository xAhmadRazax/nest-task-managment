@baseUrl = http://localhost:3000/api/v1
@content-type = application/json
### 
# @name registerUser
POST {{baseUrl}}/auth/register
Content-Type:{{content-type}}

{
    "name":"fake",
    "email":"fake@fake12.com",
    "password":"Fake123*"
}

### 
# @name loginUser
POST {{baseUrl}}/auth/login
Content-Type:{{content-type}}

{
     "email":"fake@fake.com",
    "password":"Fake123*"
}

### setting access token
@accessToken = {{loginUser.response.body.accessToken}}


### 
# @name changePassword
POST {{baseUrl}}/auth/change-password
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}

{
    "currentPassword":"Fake123*",
    "newPassword":"Fakefake12*"
}

### 
# @name forgotPassword
POST {{baseUrl}}/auth/forgot-password
Content-Type:{{content-type}}

{
    "email":"fake@fake.com"
}

### setting access token
@passwordResetUrl = {{forgotPassword.response.body.passwordResetUrl}}


### 
# @name resetPassword
POST {{passwordResetUrl}}
Content-Type:{{content-type}}

{
    "password":"Fake123*"
}



### logout user
# @name logout
POST  {{baseUrl}}/auth/logout
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}



### getting user
# @name getMe

GET {{baseUrl}}/auth/me
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}


### create task
# @name tasks
POST {{baseUrl}}/tasks
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}

{
    "title":"learn NestJs 23",
    "description":"ja",
    "dueDate":"2026-03-29T02:21:15.000Z",
    "subTasks":[{
    "title":"learn NestJs",
    "description":"ja",
    "dueDate":"2026-03-29T02:21:15.000Z"}
    ]

}

### update task
# @name updateTask
PATCH {{baseUrl}}/tasks/126
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}

{
    "title":"learn banana 53",
    "description":"ja",
    "targetDate":"2026-03-29T02:21:15.000Z",
     "subTasks":[{
    "title":"learn NestJs bone",
    "description":"ja",
    "dueDate":"2026-03-29T02:21:15.000Z"}
    ]

}


### find All Task
# @name getAllTasks
Get {{baseUrl}}/tasks?
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}




### find All Task with pagination
# @name getAllTasksPaginationFilter
Get {{baseUrl}}/tasks?page=2&limit=1
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}




### find All Task with search
# @name getAllTasksSearchFilter
Get {{baseUrl}}/tasks?search=finish
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}

###
# @name getAllTasksStatusFilter
Get {{baseUrl}}/tasks?status=OPEN
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}



### find a Task
# @name getATasks
Get {{baseUrl}}/tasks/125
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}





### add subTasks
# @name addSubTasks
Post {{baseUrl}}/tasks/125/subTasks
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}

[{
    "title":"idk mannnnnnnn",
    "description":"ja",
    "dueDate":"2026-03-28T02:21:15.000Z"
}
]


### change task status
# @name changeTaskStatus
PATCH  {{baseUrl}}/tasks/125/status
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}

{
    "newStatus":"ABANDONED"
}

### delete Task
# @name deleteTask
Delete {{baseUrl}}/tasks/125
Content-Type:{{content-type}}
Authorization: Bearer {{accessToken}}